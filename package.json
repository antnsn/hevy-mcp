{
  "name": "@antnsn/hevy-mcp",
  "version": "0.1.1",
  "description": "MCP server for the Hevy workout tracker API",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/antnsn/hevy-mcp.git"
  },
  "homepage": "https://github.com/antnsn/hevy-mcp#readme",
  "bugs": {
    "url": "https://github.com/antnsn/hevy-mcp/issues"
  },
  "author": "Marius Antonsen",
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "hevy-mcp": "dist/index.js"
  },
  "main": "dist/index.js",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc && chmod +x dist/index.js",
    "prepublishOnly": "npm run build",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "mcp",
    "hevy",
    "fitness",
    "workout"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
